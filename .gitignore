# Build output
bin/
obj/
out/

# .NET
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/
*.nupkg
*.snupkg

# SQLite database files — never commit local databases
*.db
*.db-shm
*.db-wal

# ASP.NET user secrets
**/appsettings.Development.json

# E2E test local overrides (credentials, environment-specific URLs)
**/testsettings.local.json

# Visual test output — actual screenshots, diff images, and HTML report
# Baselines (Tests/Visual/Baselines/) are committed; these are generated at runtime
**/VisualResults/

# Node / frontend
client-app/node_modules/
client-app/dist/
client-app/dist-sr/
client-app/*.local
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
*.swp
*.swo
